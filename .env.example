NODE_ENV=development
PORT=4000

# Set this before any real beta or production deployment.
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d

# Leave blank to allow all origins in local development only.
# For beta/production, set the real frontend origin or a comma-separated list.
# Example: https://yourapp.vercel.app
CORS_ORIGIN=
TRUST_PROXY=0

# Local Mongo example:
MONGODB_URI=mongodb://127.0.0.1:27017/boitekong-pulse

# Atlas example values if you are not using a full MONGODB_URI:
MONGODB_URI=mongodb+srv://your-db-user:your-db-password@cluster0.example.mongodb.net/boitekong-pulse?retryWrites=true&w=majority&appName=BoitekongPulse
MONGODB_CLUSTER_HOST=cluster0.example.mongodb.net
MONGODB_DATABASE_NAME=boitekong-pulse
MONGODB_APP_NAME=BoitekongPulse
MONGODB_USERNAME=replace-with-your-mongodb-username
MONGODB_PASSWORD=replace-with-your-mongodb-password

# Optional partitioned Mongo layout:
# - Leave MONGODB_PARTITION_MODE=single to keep everything on MONGODB_URI.
# - Set it to partitioned only after running npm run db:migrate-partitions.
MONGODB_PARTITION_MODE=single
MONGODB_URI_TWO=
MONGODB_DATABASE_NAME_TWO=boitekong-pulse
MONGODB_APP_NAME_TWO=BoitekongPulseContent
MONGODB_URI_THREE=
MONGODB_DATABASE_NAME_THREE=boitekong-pulse
MONGODB_APP_NAME_THREE=BoitekongPulseMessaging
MONGODB_URI_FOUR=
MONGODB_DATABASE_NAME_FOUR=boitekong-pulse
MONGODB_APP_NAME_FOUR=BoitekongPulseNotifications
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# SMS / OTP
SMS_APIKEY=replace-with-your-sms-api-key
SMS_BASE_URL=https://platform.clickatell.com/messages/http/send
OTP_CODE_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Migration/runtime tuning
API_BODY_LIMIT=8mb
VOICE_NOTES_PER_DAY_LIMIT=5
VOICE_NOTE_DAILY_LIMIT_TIMEZONE=Africa/Johannesburg
SERVER_REQUEST_TIMEOUT_MS=30000
SERVER_HEADERS_TIMEOUT_MS=35000
SERVER_KEEP_ALIVE_TIMEOUT_MS=5000
