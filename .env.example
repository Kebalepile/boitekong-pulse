NODE_ENV=development
PORT=4000

# Set this before any real beta or production deployment.
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=7d

# Leave blank to allow all origins in local development.
# For beta/production, set the real frontend origin or a comma-separated list.
CORS_ORIGIN=

# Local Mongo example:
MONGODB_URI=mongodb://127.0.0.1:27017/boitekong-pulse

# Atlas example values if you are not using a full MONGODB_URI:
MONGODB_URI=mongodb+srv://kmotshoana_db_user:2uXhFYvmlpmtBOMI@cluster0.6kulemc.mongodb.net/boitekong-pulse?retryWrites=true&w=majority&appName=Cluster0
MONGODB_CLUSTER_HOST=cluster0.6kulemc.mongodb.net
MONGODB_DATABASE_NAME=boitekong-pulse
MONGODB_APP_NAME=Cluster0
MONGDB_PASSWRD=2uXhFYvmlpmtBOMI
MONGODB_USERNAME=kmotshoana_db_user
MONGODB_DNS_SERVERS=8.8.8.8,1.1.1.1

# SMS / OTP
SMS_APIKEY=JHASplZARE2xP08shNVB8Q==
SMS_BASE_URL=https://platform.clickatell.com/messages/http/send
OTP_CODE_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Migration/runtime tuning
API_BODY_LIMIT=8mb
VOICE_NOTES_PER_DAY_LIMIT=5
VOICE_NOTE_DAILY_LIMIT_TIMEZONE=Africa/Johannesburg
